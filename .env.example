# Recon Multi-Agent — environment template
# Copy to .env and fill in values. No secrets are committed.

# Database
DATABASE_URL=postgresql://recon:recon@localhost:5432/recon

# DeepInfra (Gemma model endpoint)
DEEPINFRA_API_KEY=
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai
MODEL_NAME=google/gemma-4-26B-A4B-it

# Search tools (S03)
SEARCH_API_KEY=
SEARCH_ENDPOINT=
FETCH_TIMEOUT_MS=15000
FETCH_MAX_BYTES=1048576

# Coverage / budget caps
COVERAGE_MAX_ITERATIONS=3
COVERAGE_CONFIDENCE_FLOOR=0.6
MAX_QUERIES_PER_RUN=20
MAX_FETCHES_PER_RUN=30

# Runtime
LOG_LEVEL=info
