{
  "version": "1.0",
  "description": "Deny private/local IPs and known-malicious domains; allow everything else for v1.0.",
  "defaultAction": "allow",
  "allowlist": [],
  "denylist": [
    "metadata.google.internal",
    "169.254.169.254",
    "*.internal",
    "*.local",
    "localhost",
    "127.0.0.1",
    "0.0.0.0",
    "::1"
  ],
  "denyPrivate": true,
  "denyKnownMalicious": true,
  "knownMalicious": [
    "evil.com",
    "malware.example",
    "phishing.example",
    "badactor.example"
  ]
}
