{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recon.jakemorganlabs/schemas/brief.schema.json",
  "title": "Brief",
  "description": "Structured research request extracted from the raw ask.",
  "type": "object",
  "additionalProperties": false,
  "required": ["target", "slots"],
  "properties": {
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "website": { "type": "string", "format": "uri" }
      }
    },
    "slots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slot_name", "required", "question"],
        "properties": {
          "slot_name": {
            "type": "string",
            "enum": [
              "overview",
              "products",
              "funding",
              "headcount",
              "tech_stack",
              "hiring",
              "leadership",
              "recent_news",
              "risks"
            ]
          },
          "required": { "type": "boolean" },
          "question": { "type": "string", "minLength": 1 },
          "confidence_floor": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "seed_urls": {
      "type": "array",
      "items": { "type": "string", "format": "uri" }
    },
    "depth": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3,
      "default": 1
    }
  }
}
